# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here

# Server
PORT=3000
WEBHOOK_URL=https://your-domain.railway.app

# Google Drive
GOOGLE_CLIENT_EMAIL=service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_DRIVE_MASTER_FOLDER_ID=your_master_dump_folder_id
GOOGLE_DRIVE_STORIES_FOLDER_ID=your_stories_folder_id

# Notion
NOTION_TOKEN=secret_xxx
NOTION_DATABASE_ID=your_database_id_here
NOTION_STORIES_DB_ID=your_stories_database_id_here

# OpenAI (optional)
OPENAI_API_KEY=sk-xxx
OPENAI_ENABLED=true

# Polling
NOTION_POLL_INTERVAL_MS=30000
